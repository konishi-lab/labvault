# labvault 環境変数 (.env にコピーして値を設定)
# Settings クラスが LABVAULT_ prefix で自動読み込み

# チーム・ユーザー
LABVAULT_TEAM=konishi-lab
LABVAULT_USER=

# Nextcloud (ファイルストレージ)
LABVAULT_NEXTCLOUD_URL=https://arim.mdx.jp/nextcloud
LABVAULT_NEXTCLOUD_USER=
LABVAULT_NEXTCLOUD_PASSWORD=
LABVAULT_NEXTCLOUD_GROUP_FOLDER=large/24UTARIM004

# GCP (Firestore メタデータ)
LABVAULT_GCP_PROJECT=klab-laser-process
LABVAULT_FIRESTORE_DATABASE=labvault

# platform 経由で Nextcloud credentials を取得する場合はこれを設定。
# ADC (gcloud auth application-default login) の access token で認証される。
# 設定しない場合は上記の LABVAULT_NEXTCLOUD_PASSWORD を直接使う (開発用)。
# LABVAULT_PLATFORM_URL=https://labvault-api-355809880738.asia-northeast1.run.app
